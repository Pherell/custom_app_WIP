# =================================================================
# TACTICAL DRONE FLEET - C2 SERVER CONFIGURATION
# =================================================================
# Modify these ports if they conflict with services already running 
# on your host machine.

# 1. MQTT Broker
# TCP Port used by the Android Drone Client to send telemetry
MQTT_TCP_PORT=1883
# WebSockets Port used by the React Web UI to receive telemetry
MQTT_WS_PORT=9001

# Change this to your Production MQTT Broker IP (e.g., tcp://192.168.180.31:1883)
MQTT_BROKER=

MQTT_USERNAME=avarell
MQTT_PASSWORD=avAREl1z02B

# 2. Offline Map Server
# Port to serve the local .mbtiles satellite imagery
MAP_SERVER_PORT=8080

# 3. Web UI (Future / Production)
# Port to serve the compiled React Command Center
WEB_UI_PORT=8013

# 4. WebRTC Video Signaling & Telemetry Backend
# Port for negotiating the live H.264 video streams and persisting data
BACKEND_PORT=9005

# 5. S3 Bucket Configuration (BT-Prod Cluster)
S3_ACCESS_KEY=dji-sdk
S3_SECRET_KEY=isi_key_disini
