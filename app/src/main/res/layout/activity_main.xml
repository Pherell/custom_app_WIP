<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:keepScreenOn="true"
    tools:context=".MainActivity">

    <!-- FULLSCREEN CAMERA FEED -->
    <SurfaceView
        android:id="@+id/fpvSurface"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- PIP SECONDARY CAMERA FEED (e.g. THERMAL) -->
    <SurfaceView
        android:id="@+id/pipSurface"
        android:layout_width="160dp"
        android:layout_height="90dp"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/modeSwitcher"
        app:layout_constraintEnd_toEndOf="parent" />
        
    <ImageView
        android:id="@+id/focusReticle"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_focus_reticle"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <!-- STRATEGY MAP (Hidden by default) -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- MAPPING SETTINGS SIDE PANEL -->
    <ScrollView
        android:id="@+id/layoutMappingSettings"
        android:layout_width="250dp"
        android:layout_height="0dp"
        android:background="#DD1A1A1A"
        android:padding="16dp"
        android:visibility="gone"
        android:layout_marginStart="70dp"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="60dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAP PLAN"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp"/>
                
            <!-- Altitude -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Altitude (m)"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace"/>
            <EditText
                android:id="@+id/etMapAlt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00FF00"
                android:background="#2200FF00"
                android:padding="8dp"
                android:inputType="numberDecimal"
                android:text="50.0"
                android:layout_marginBottom="12dp"
                android:fontFamily="monospace"/>

            <!-- Speed -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speed (m/s)"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace"/>
            <EditText
                android:id="@+id/etMapSpeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00FF00"
                android:background="#2200FF00"
                android:padding="8dp"
                android:inputType="numberDecimal"
                android:text="5.0"
                android:layout_marginBottom="12dp"
                android:fontFamily="monospace"/>

            <!-- Overlap -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Side Overlap (%)"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace"/>
            <EditText
                android:id="@+id/etMapOverlap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00FF00"
                android:background="#2200FF00"
                android:padding="8dp"
                android:inputType="number"
                android:text="70"
                android:layout_marginBottom="12dp"
                android:fontFamily="monospace"/>
                
            <!-- Gimbal Pitch -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gimbal Pitch (deg)"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace"/>
            <EditText
                android:id="@+id/etMapPitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00FF00"
                android:background="#2200FF00"
                android:padding="8dp"
                android:inputType="numberSigned"
                android:text="-90"
                android:layout_marginBottom="12dp"
                android:fontFamily="monospace"/>
                
            <!-- Pattern -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pattern"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace"/>
            <Spinner
                android:id="@+id/spnMapPattern"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2200FF00"
                android:padding="8dp"
                android:layout_marginBottom="12dp"/>
                
            <!-- Mapping Mode (Quick vs Pro) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Capture Mode"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace"/>
            <Spinner
                android:id="@+id/spnMapMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2200FF00"
                android:padding="8dp"
                android:layout_marginBottom="16dp"/>
                
            <!-- Import Native KMZ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Import Native KMZ (URL)"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace"/>
            <EditText
                android:id="@+id/etKmzUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00FF00"
                android:background="#2200FF00"
                android:padding="8dp"
                android:hint="http://storage/mission.kmz"
                android:textColorHint="#555555"
                android:inputType="textUri"
                android:layout_marginBottom="8dp"
                android:fontFamily="monospace"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <Button
                    android:id="@+id/btnImportKmzLocal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FROM STORAGE"
                    android:backgroundTint="#880000FF"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp"/>
                <Button
                    android:id="@+id/btnImportKmz"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FROM URL"
                    android:backgroundTint="#4400FF00"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:textSize="10sp"/>
            </LinearLayout>
            <Button
                android:id="@+id/btnShowSavedKmz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SHOW SAVED MISSIONS"
                android:backgroundTint="#44FFAA00"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:layout_marginBottom="8dp"/>
                
            <Button
                android:id="@+id/btnClearKmz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CLEAR MAP/KMZ"
                android:backgroundTint="#88FF0000"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:layout_marginBottom="16dp"/>
                
        </LinearLayout>
    </ScrollView>

    <!-- AR HOME POINT -->
    <TextView
        android:id="@+id/arHomePoint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="[ H ]\nHOME"
        android:textAlignment="center"
        android:textColor="#FFFF00"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="3"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- LEFT ALERTS -->
    <LinearLayout
        android:id="@+id/alertsLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="@id/reticle"
        app:layout_constraintBottom_toBottomOf="@id/reticle"
        app:layout_constraintEnd_toStartOf="@id/reticle"
        android:layout_marginEnd="16dp">
        
        <TextView android:id="@+id/alertThermal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="THERMAL" android:textColor="#FF0000" android:textSize="14sp" android:textStyle="bold" android:fontFamily="monospace" android:padding="8dp" android:visibility="gone" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/alertLow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOW BAT" android:textColor="#FF0000" android:textSize="14sp" android:textStyle="bold" android:fontFamily="monospace" android:padding="8dp" android:visibility="gone" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/alertLoss" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SIG LOSS" android:textColor="#FF0000" android:textSize="14sp" android:textStyle="bold" android:fontFamily="monospace" android:padding="8dp" android:visibility="gone" />
    </LinearLayout>

    <!-- RIGHT ALERTS -->
    <LinearLayout
        android:id="@+id/alertsRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="@id/reticle"
        app:layout_constraintBottom_toBottomOf="@id/reticle"
        app:layout_constraintStart_toEndOf="@id/reticle"
        android:layout_marginStart="16dp">
        
        <TextView android:id="@+id/alertStorage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STORAGE" android:textColor="#FF0000" android:textSize="14sp" android:textStyle="bold" android:fontFamily="monospace" android:padding="8dp" android:visibility="gone" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/alertBlock" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NFZ BLOCK" android:textColor="#FF0000" android:textSize="14sp" android:textStyle="bold" android:fontFamily="monospace" android:padding="8dp" android:visibility="gone" />
    </LinearLayout>

    <!-- OBSTACLE RADAR -->
    <com.dji.recreate2.ObstacleRadarView
        android:id="@+id/obstacleRadar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- TACTICAL OVERLAY / HUD -->
    <ImageView
        android:id="@+id/reticle"
        android:layout_width="159dp"
        android:layout_height="125dp"
        android:src="@drawable/reticle_corners"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- LRF RETICLE AND DATA -->
    <ImageView
        android:id="@+id/lrfReticle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_focus_reticle"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvLrfData"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LRF: OFF"
        android:textColor="#00FF00"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:background="#66000000"
        android:padding="4dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/lrfReticle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- OBSTACLE ALERT BELOW RETICLE -->
    <TextView
        android:id="@+id/alertObstacle" 
        android:layout_width="wrap_content" 
        android:layout_height="wrap_content" 
        android:text="OBSTACLE AHEAD" 
        android:textColor="#FF0000" 
        android:textSize="14sp" 
        android:textStyle="bold" 
        android:fontFamily="monospace" 
        android:padding="8dp" 
        android:visibility="gone" 
        app:layout_constraintTop_toBottomOf="@id/reticle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- GIMBAL PITCH INDICATOR -->

    <!-- HEADING TAPE (Aviation Style) -->
    <TextView
        android:id="@+id/tvGimbalStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:fontFamily="monospace"
        android:text="0"
        android:textColor="#AA00FF00"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/reticle"
        app:layout_constraintEnd_toStartOf="@id/reticle"
        app:layout_constraintTop_toTopOf="@id/reticle"
        app:layout_constraintVertical_bias="0.075" />

    <com.dji.recreate2.CompassView
        android:id="@+id/compassView"
        android:layout_width="250dp"
        android:layout_height="40dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="50dp" />
    
    <!-- STATUS INFO MOVED TO SYS DIALOG -->

    <!-- TOP TELEMETRY -->
    <LinearLayout
        android:id="@+id/topTelemetry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:gravity="center"
        android:background="#88000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:id="@+id/tvServerStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C2: OFFLINE" android:textColor="#FF0000" android:textStyle="bold" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginEnd="16dp" />
        <TextView android:id="@+id/tvCoords" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NAV: --.----, --.----" android:textColor="#00FF00" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginEnd="16dp" />
        <TextView android:id="@+id/tvAltitude" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ALT: ---.-M" android:textColor="#00FF00" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginEnd="16dp" />
        <TextView android:id="@+id/tvSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SPD: --.-M/S" android:textColor="#00FF00" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginEnd="16dp" />
        <TextView android:id="@+id/tvHeading" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HDG: ---°" android:textColor="#00FF00" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginEnd="16dp" />
        <TextView android:id="@+id/tvGps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SAT: --" android:textColor="#00FF00" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginEnd="16dp" />
        <TextView android:id="@+id/tvSignal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--%" android:textColor="#00FF00" android:textSize="12sp" android:fontFamily="monospace" android:layout_marginEnd="16dp" android:drawableStart="@drawable/ic_signal" android:drawablePadding="4dp" />
        <TextView android:id="@+id/tvBattery" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--%" android:textColor="#00FF00" android:textSize="12sp" android:fontFamily="monospace" android:drawableStart="@drawable/ic_battery" android:drawablePadding="4dp" />
    </LinearLayout>

    <!-- LENS SWITCHER -->
    <LinearLayout
        android:id="@+id/lensSwitcher"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#44000000"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topTelemetry"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView android:id="@+id/btnLensWide" android:layout_width="50dp" android:layout_height="24dp" android:text="WIDE" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:gravity="center" android:background="@drawable/bg_glass_btn_active" />
        <TextView android:id="@+id/btnLensZoom" android:layout_width="50dp" android:layout_height="24dp" android:text="ZOOM" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:gravity="center" android:background="@drawable/bg_glass_btn" android:layout_marginStart="4dp" />
        <TextView android:id="@+id/btnLensIr" android:layout_width="50dp" android:layout_height="24dp" android:text="IR" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:gravity="center" android:background="@drawable/bg_glass_btn" android:layout_marginStart="4dp" />
        <TextView android:id="@+id/btnTogglePip" android:layout_width="50dp" android:layout_height="24dp" android:text="PIP" android:textColor="#FFFF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:gravity="center" android:background="@drawable/bg_glass_btn" android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- LEFT FLIGHT CONTROLS -->
    <LinearLayout
        android:id="@+id/leftFlightControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="160dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <TextView android:id="@+id/tvControlStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CTRL: CAM" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="#4400FF00" android:padding="4dp" android:layout_marginBottom="16dp" android:visibility="gone" />
        <TextView android:id="@+id/btnTakeoff" android:layout_width="40dp" android:layout_height="24dp" android:text="TAK" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="@drawable/bg_glass_btn" android:gravity="center" android:layout_marginBottom="4dp" />
        <TextView android:id="@+id/btnManualStart" android:layout_width="40dp" android:layout_height="24dp" android:text="ENG" android:textColor="#FF0000" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="@drawable/bg_glass_btn" android:gravity="center" android:layout_marginBottom="4dp" />
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:id="@+id/btnLand" android:layout_width="40dp" android:layout_height="24dp" android:text="LND" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="@drawable/bg_glass_btn" android:gravity="center" />
            <TextView android:id="@+id/btnCancelMission" android:layout_width="24dp" android:layout_height="24dp" android:text="X" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_circle_red" android:layout_marginStart="8dp" android:visibility="gone" />
        </LinearLayout>
        <TextView android:id="@+id/btnRth" android:layout_width="40dp" android:layout_height="24dp" android:text="RTH" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="@drawable/bg_glass_btn" android:gravity="center" android:layout_marginBottom="4dp" />
        <TextView android:id="@+id/btnPau" android:layout_width="40dp" android:layout_height="24dp" android:text="PAU" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="@drawable/bg_glass_btn" android:gravity="center" android:layout_marginBottom="4dp" />
        <TextView android:id="@+id/btnSetHome" android:layout_width="40dp" android:layout_height="24dp" android:text="SET" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="@drawable/bg_glass_btn" android:gravity="center" />
    </LinearLayout>

    <!-- TOP RIGHT ACTION CONTROLS -->
    <LinearLayout
        android:id="@+id/rightActionControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_marginEnd="32dp"
        android:gravity="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5">
        
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
            <!-- Circular Gimbal Reset Button -->
            <TextView android:id="@+id/btnCenterGimbal" android:layout_width="28dp" android:layout_height="28dp" android:text="GMB" android:textColor="#00FF00" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_circle_green" android:layout_marginEnd="8dp" android:layout_gravity="center_vertical"/>
            
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:id="@+id/btnLrfToggle" android:layout_width="40dp" android:layout_height="24dp" android:text="LRF" android:textColor="#FFFF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="@drawable/bg_glass_btn" android:gravity="center" android:visibility="gone" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/btnCapture" android:layout_width="40dp" android:layout_height="24dp" android:text="IMG" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="@drawable/bg_glass_btn" android:gravity="center" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/btnRecord" android:layout_width="40dp" android:layout_height="24dp" android:text="REC" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="@drawable/bg_glass_btn" android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
        
        <TextView android:id="@+id/btnToggleJoysticks" android:layout_width="40dp" android:layout_height="24dp" android:text="STK" android:textColor="#00FF00" android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace" android:background="@drawable/bg_glass_btn" android:gravity="center" android:layout_marginBottom="4dp" />
