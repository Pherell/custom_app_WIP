<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DJI TACTICAL GATEWAY"
        android:textColor="#00FF00"
        android:textSize="24sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STATUS: INITIALIZING..."
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnPair"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/btnPair"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="[ INITIATE PAIRING ]"
        android:textColor="#00FF00"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:background="#2200FF00"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnFlyMode"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/btnFlyMode"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="[ ENTER FLY MODE ]"
        android:textColor="#000000"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:background="#00FF00"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnPair"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnServerSettings"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/btnServerSettings"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="[ SERVER CONFIG ]"
        android:textColor="#00FF00"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:background="#2200FF00"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/btnFlyMode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
